<div class="card">
  <h1>Login</h1>

  <%= form_with url: login_path do %>
    <p>
      <%= label_tag :username %><br>
      <%= text_field_tag :username %>
    </p>

    <p>
      <%= label_tag :password %><br>
      <%= password_field_tag :password %>
    </p>

    <p>
      <%= submit_tag "Login", class: "btn" %>
    </p>
  <% end %>

  <p>
    Don't have an account?
    <%= link_to "Sign up", signup_path %>
  </p>
</div>